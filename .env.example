# ─── AI Provider ────────────────────────────────────────────────────────────────
# Choose which AI provider to use for hook detection scoring.
# Options: openai | anthropic | gemini
# Leave blank to use audio-only analysis (no API key required).
AI_PROVIDER=openai

# ─── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Gemini ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=AI...
