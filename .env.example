# ─── AI Provider ────────────────────────────────────────────────────────────────
# Choose which AI provider to use for hook detection scoring.
# Options: typhoon | openai | anthropic | gemini
# Leave blank to auto-detect from the first configured API key below.
AI_PROVIDER=typhoon

# ─── OpenTyphoon (Typhoon) ──────────────────────────────────────────────────────
# OpenAI-compatible API: https://docs.opentyphoon.ai/en/
THPHOON_API_KEY=sk-...
# TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
# TYPHOON_MODEL=typhoon-v2.5-30b-a3b-instruct
# TYPHOON_TEMPERATURE=0.6
# TYPHOON_TOP_P=0.6
# TYPHOON_MAX_TOKENS=512

# ─── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Gemini ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=AI...
